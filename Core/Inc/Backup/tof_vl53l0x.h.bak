#ifndef TOF_VL53L0X_H
#define TOF_VL53L0X_H

#include "vl53l0x_api.h"
#include "i2c.h"

/**
 * @brief Struktura obsługująca czujnik VL53L0X.
 */
typedef struct
{
  VL53L0X_Dev_t dev;                            ///< Struktura urządzenia VL53L0X.
  VL53L0X_RangingMeasurementData_t rangingData; ///< Dane pomiarowe.
  I2C_HandleTypeDef *i2cHandle;                 ///< Uchwyt I2C.
  uint8_t i2cAddress;                           ///< Adres I2C czujnika.
} VL53L0X_Handler;

/**
 * @brief Inicjalizuje czujnik VL53L0X.
 *
 * @param handler Wskaźnik do struktury obsługującej czujnik.
 * @param i2cHandle Wskaźnik do uchwytu I2C.
 * @param i2cAddress Adres I2C czujnika.
 */
void VL53L0X_Init(VL53L0X_Handler *handler, I2C_HandleTypeDef *i2cHandle, uint8_t i2cAddress);

/**
 * @brief Rozpoczyna pomiary w trybie ciągłym dla czujnika VL53L0X.
 *
 * @param handler Wskaźnik do struktury obsługującej czujnik.
 */
void VL53L0X_Start(VL53L0X_Handler *handler);

/**
 * @brief Pobiera zmierzoną odległość w milimetrach.
 *
 * @param handler Wskaźnik do struktury obsługującej czujnik.
 * @return uint16_t Zmierzona odległość w milimetrach.
 */
uint16_t VL53L0X_GetDistance(VL53L0X_Handler *handler);

#endif // TOF_VL53L0X_H