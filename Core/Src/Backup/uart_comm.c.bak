#include "uart_comm.h"
#include "stm32l4xx_hal_def.h"
#include "stm32l4xx_hal_uart.h"
#include <string.h>

volatile char cmd_line[RX_BUFF_LEN];
volatile uint8_t cmd_ready = 0;

static char rx_buff[RX_BUFF_LEN];
static uint8_t idx = 0;

static UART_HandleTypeDef *uart;

void uart_init(UART_HandleTypeDef *huart)
{
  uart = huart;
}

void uart_rx_byte(uint8_t byte)
{
  if (cmd_ready)
    return;

  if (byte == '\n' || byte == '\r')
  {
    if (idx > 0)
    {
      rx_buff[idx++] = '\0';
      memcpy((void*)cmd_line, rx_buff, idx);
      cmd_ready = 1;
      idx = 0;
    }
  }
  else
  {
    if (idx < RX_BUFF_LEN - 1)
    {
      rx_buff[idx++] = byte;
    }
    else
    {
      idx = 0;
    }
  }
}

void uart_send_str(const char *str)
{
  HAL_UART_Transmit(uart, (uint8_t *)str, sizeof(str), HAL_MAX_DELAY);
}